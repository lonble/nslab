# Custom Snort rules for the lab IDS demo.
# sids are kept >= 1000000 (Snort's reserved range for local/custom rules)
# to avoid collisions with any official/community ruleset.

# 1. ICMP traffic to a LAN host - triggered by: ping <gateway-ip>
alert icmp any any -> $HOME_NET any (msg:"ICMP traffic to internal host"; sid:1000001; rev:1;)

# 2. Port scan detection via SYN threshold - triggered by: nmap -p 1-100 <gateway-ip>
alert tcp any any -> $HOME_NET any (msg:"Possible Nmap scan detected"; flags:S; threshold:type both, track by_src, count 20, seconds 5; sid:1000002; rev:1;)

# 3. Telnet connection attempt - triggered by: nc -zv <gateway-ip> 23
alert tcp any any -> $HOME_NET 23 (msg:"Telnet connection attempt"; sid:1000003; rev:1;)

# Changes to make in /etc/snort/snort.conf
# (the stock file is huge and mostly boilerplate — only these lines matter)

# Near the top, network variables:
ipvar HOME_NET 192.168.0.0/24
ipvar EXTERNAL_NET !$HOME_NET

# RULE_PATH should already point here by default:
var RULE_PATH /etc/snort/rules

# Near the bottom, make sure local rules are included:
include $RULE_PATH/local.rules
